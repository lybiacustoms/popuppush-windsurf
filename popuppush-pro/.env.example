# ============================================
# Pop-up Push Pro - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# Database Configuration
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=popuppush
DB_USER=popuppush
DB_PASSWORD=SecurePass123!

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=RedisPass123

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=YourSuperSecretJWTKey2024
JWT_EXPIRES_IN=7d

# ============================================
# Sports API (API-Football)
# Get your API key from: https://www.api-football.com/
# ============================================
SPORTS_API_KEY=your_api_football_key_here
SPORTS_API_BASE_URL=https://v3.football.api-sports.io

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# Storage & Uploads
# ============================================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=100

# ============================================
# Feature Flags
# ============================================
ENABLE_ANALYTICS=true
ENABLE_AUTO_MATCHES=true
ENABLE_SMART_ADS=true

# ============================================
# Security
# ============================================
BCRYPT_ROUNDS=12
CORS_ORIGIN=*

# ============================================
# pgAdmin (Optional - Database Management)
# ============================================
PGADMIN_EMAIL=admin@popuppush.com
PGADMIN_PASSWORD=admin123

# ============================================
# Player App Configuration
# ============================================
PLAYER_API_BASE_URL=http://your-server:3001
PLAYER_SOCKET_URL=ws://your-server:3001

# ============================================
# Remote App Configuration
# ============================================
REMOTE_API_URL=http://your-server/api
REMOTE_SOCKET_URL=ws://your-server

# ============================================
# Monitoring (Optional)
# ============================================
SENTRY_DSN=
LOG_LEVEL=info

# ============================================
# Cloud Provider (AWS/Azure/DO)
# ============================================
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# ============================================
# NOTES:
# 1. Change all passwords in production!
# 2. Get API-Football key for sports integration
# 3. Configure SMTP for email notifications
# 4. Set up SSL certificates for HTTPS
# 5. Update PLAYER_* URLs with your server IP/domain
# ============================================
