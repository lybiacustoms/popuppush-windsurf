# Pop-up Push Pro - Production Environment Variables
# These will be overridden by Vercel Environment Variables

# Backend API URL (Railway or Render)
VITE_API_URL=https://popuppush-api.up.railway.app/api

# WebSocket URL (use wss:// for secure connection)
VITE_SOCKET_URL=wss://popuppush-api.up.railway.app

# NOTE: Update these URLs after deploying your backend
# Railway URL format: https://your-app.up.railway.app
# Render URL format: https://your-app.onrender.com
